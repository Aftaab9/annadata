# data.gov.in Agmarknet — https://data.gov.in (free, no card)
VITE_DATA_GOV_API_KEY=your_key_here

# Local Ollama
VITE_OLLAMA_MODEL=llama3.2:3b

# LLM fallback chain (server-side only — set in Vercel Project → Environment Variables)
# Never prefix these with VITE_ (keeps keys off the client bundle)
CEREBRAS_API_KEY=          # https://cloud.cerebras.ai — free, no card
GROQ_API_KEY=              # https://console.groq.com — free, no card (also Whisper)
OPENROUTER_API_KEY=        # https://openrouter.ai — optional free backup

# Supabase marketplace (free tier, no card) — see SUPABASE_SETUP.md
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional model overrides
# CEREBRAS_MODEL=llama-3.3-70b
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
